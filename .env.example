# Copiar este archivo a .env (NUNCA commitear .env, ya esta en .gitignore).
# Generar un valor unico antes del primer deploy:
#   openssl rand -hex 32
#
# Esta misma clave se usa en dos lugares:
#   1. services/ms-pedidos (la registra como API Key de API Gateway en el
#      endpoint protegido POST /pedidos/externos).
#   2. oci/api-rappi/deploy.sh (la envia como header x-api-key al llamar
#      a ese endpoint). Por eso vive en un .env compartido en la raiz.
RAPPI_API_KEY=reemplaza-esto-con-un-valor-aleatorio
